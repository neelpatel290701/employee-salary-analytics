# Example environment file. Copy this to .env (gitignored) and edit per
# environment. See docs/10-deployment.md §3 for the full variable inventory
# and the rules around secrets.

# === Backend ===

# Express behaviour, pino log format, stack-trace exposure.
NODE_ENV=development

# Port Express listens on. Railway injects PORT automatically in production.
PORT=3000

# Prisma connection string. The dev value below matches docker-compose.yml.
# In production this is the Railway MySQL plugin URL with ?connection_limit=5.
DATABASE_URL=mysql://app:app@localhost:3307/employee_analytics?connection_limit=5

# Pre-created shadow database used by `prisma migrate dev` for drift
# detection. Only needed in development - production deployments use
# `prisma migrate deploy` which does not need a shadow database.
SHADOW_DATABASE_URL=mysql://app:app@localhost:3307/employee_analytics_shadow

# pino log level. info in production, debug in development.
LOG_LEVEL=debug

# Comma-separated allow-list for CORS. The Vite dev server runs on :5173.
# In production this is the Vercel deployment URL.
ALLOWED_ORIGINS=http://localhost:5173

# === Frontend ===

# Base URL for the API client. Read once at build time and frozen into the
# bundle. In dev, the Vite proxy forwards /api -> backend, so this value is
# effectively unused. In production this is the Railway backend URL.
VITE_API_URL=http://localhost:3000

# === Tests (backend only) ===
# Backed by the integration suite. Lives in backend/.env.test (gitignored)
# and is what `npm run test:integration` reads.
# DATABASE_URL=mysql://app:app@localhost:3307/employee_analytics_test
